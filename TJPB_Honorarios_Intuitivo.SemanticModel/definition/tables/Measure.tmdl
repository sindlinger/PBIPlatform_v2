	measure 'Campeão no Contexto (Nome)' =
			
			
			VAR TopPerito =
			    TOPN(
			        1,
			        SUMMARIZE(
			            ALLSELECTED(Orders.'Product Name'),
			            Orders.'Product Name',
			            "ValorPerito", [Total Sales]
			        ),
			        [ValorPerito], DESC,
			        Orders.'Product Name', ASC
			    )
			RETURN
			    MAXX(TopPerito, Orders.'Product Name')
		lineageTag: c4f6c6c6-b3a1-4b3b-99d2-8704f57f2b4f

	measure 'Campeão no Contexto (Valor)' =
			
			
			VAR TopPerito =
			    TOPN(
			        1,
			        SUMMARIZE(
			            ALLSELECTED(Orders.'Product Name'),
			            Orders.'Product Name',
			            "ValorPerito", [Total Sales]
			        ),
			        [ValorPerito], DESC,
			        Orders.'Product Name', ASC
			    )
			RETURN
			    MAXX(TopPerito, [ValorPerito])
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: 281b55ca-0b12-48e8-b4d7-9e61c12b6118

	measure 'Campeão no Contexto' =
			
			
			VAR Nome = [Campeão no Contexto (Nome)]
			VAR Valor = [Campeão no Contexto (Valor)]
			RETURN
			    IF(
			        ISBLANK(Valor),
			        BLANK(),
			        Nome & " | " & FORMAT(Valor, "R$ #,##0.00")
			    )
		lineageTag: 07f92466-1a81-4c8c-b3f7-17a396699361

	measure 'Total Sales RM João Pessoa' =
			
			
			
			CALCULATE(
			    [Total Sales],
			    KEEPFILTERS(
			        Orders[State Mapa] IN {
			            "João Pessoa",
			            "Joao Pessoa",
			            "Bayeux",
			            "Cabedelo",
			            "Conde",
			            "Santa Rita"
			        }
			    )
			)
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: 1c3c13d9-8b16-4e2d-9d34-c14f6a0b5c11

