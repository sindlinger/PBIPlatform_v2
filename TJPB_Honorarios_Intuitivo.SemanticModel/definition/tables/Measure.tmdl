	measure 'Gasto Mês Atual' = CALCULATE([Total Sales], DATESMTD('Date'[Date]))
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: 6db42ec4-6b0d-4ac6-aec0-d6a01f5f00f1

	measure 'Gasto Semana Atual' =
			
			
			VAR DataRef = MAX('Date'[Date])
			VAR InicioSemana = DataRef - WEEKDAY(DataRef, 2) + 1
			VAR FimSemana = InicioSemana + 6
			RETURN
			    CALCULATE(
			        [Total Sales],
			        DATESBETWEEN('Date'[Date], InicioSemana, FimSemana)
			    )
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: e9c3df92-f4c2-4df4-803f-c5a426ca7603

	measure 'Gasto Ano Atual' = CALCULATE([Total Sales], DATESYTD('Date'[Date]))
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: 8f19a17a-8344-4d74-b2f0-9fbc2dc9f349

	measure 'Gasto Mês Anterior' = CALCULATE([Total Sales], DATEADD('Date'[Date], -1, MONTH))
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: 727f4dc0-622d-44e3-83b2-8996f9074ea8

	measure 'Gasto Semana Anterior' =
			
			
			VAR DataRef = MAX('Date'[Date])
			VAR InicioSemana = DataRef - WEEKDAY(DataRef, 2) + 1
			VAR InicioSemanaAnterior = InicioSemana - 7
			VAR FimSemanaAnterior = InicioSemana - 1
			RETURN
			    CALCULATE(
			        [Total Sales],
			        DATESBETWEEN('Date'[Date], InicioSemanaAnterior, FimSemanaAnterior)
			    )
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: 3d22030e-bfbe-4e4f-9995-3f9581417ce3

	measure 'Gasto Ano Anterior' = CALCULATE([Total Sales], DATEADD('Date'[Date], -1, YEAR))
		formatString: R$ #,0.00;(R$ #,0.00);R$ #,0.00
		lineageTag: a13f0f35-0f87-422a-93f6-32e907d9f25d

	measure 'Variação Mensal %' =
			
			
			DIVIDE(
			    [Gasto Mês Atual] - [Gasto Mês Anterior],
			    [Gasto Mês Anterior]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6ea5b221-843e-4ef2-9f08-7f8cc79ad478

	measure 'Variação Semanal %' =
			
			
			DIVIDE(
			    [Gasto Semana Atual] - [Gasto Semana Anterior],
			    [Gasto Semana Anterior]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5848fe36-ea89-45a4-a99e-165cf1a6405d

	measure 'Variação Anual %' =
			
			
			DIVIDE(
			    [Gasto Ano Atual] - [Gasto Ano Anterior],
			    [Gasto Ano Anterior]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 4961d0a4-f0aa-4308-aee5-c410f83131ad

