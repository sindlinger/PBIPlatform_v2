	measure 'Sales City Label' =
			
			
			
			DIVIDE(
			    SUM('Orders'[Sales]),
			    CALCULATE(
			        SUM('Orders'[Sales]),
			        REMOVEFILTERS('Orders'),
			        KEEPFILTERS(VALUES('Orders'[City])),
			        KEEPFILTERS(VALUES('Date'[Year]))
			    )
			)
		lineageTag: e77b8579-df02-4ac3-8b89-9c4926dbcc0e

