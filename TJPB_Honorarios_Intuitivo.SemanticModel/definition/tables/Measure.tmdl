	measure 'Returns YoY %' =
			
			
			
			VAR CurrentYear = [Count Orders Returned]
			VAR PreviousYears =
			    CALCULATE ( [Count Orders Returned], DATEADD ( 'Date'[Date], -1, YEAR ) )
			RETURN
			    DIVIDE ( CurrentYear - PreviousYears, PreviousYears )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: afdd6471-1ead-45aa-b6a4-94f169fa9e18

	measure 'SMA Sales 2Y' =
			
			VAR SelectedYear = SELECTEDVALUE('Date'[Year])
			
			VAR SalesY1 =
			    CALCULATE(
			        SUM( Orders[Sales] ),
			        REMOVEFILTERS('Date'),
			        FILTER(
			            ALL( Orders[Order Date] ),
			            YEAR( DATEVALUE( Orders[Order Date] ) ) = SelectedYear
			        )
			    )
			
			VAR SalesY2 =
			    CALCULATE(
			        SUM( Orders[Sales] ),
			        REMOVEFILTERS('Date'),
			        FILTER(
			            ALL( Orders[Order Date] ),
			            YEAR( DATEVALUE( Orders[Order Date] ) ) = SelectedYear - 1
			        )
			    )
			
			RETURN
			DIVIDE( SalesY1 * 4 + SalesY2, 5 )
		lineageTag: e5b39223-2480-43ba-b81f-bd7bb696528b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'SMA Units Sold 2Y' =
			
			
			
			VAR SelectedYear = SELECTEDVALUE('Date'[Year])
			
			VAR UY1 =
			    CALCULATE(
			        [Units Sold],
			        REMOVEFILTERS('Date'),
			        FILTER(
			            ALL( Orders[Order Date] ),
			            YEAR( DATEVALUE( Orders[Order Date] ) ) = SelectedYear
			        )
			    )
			
			VAR UY2 =
			    CALCULATE(
			        [Units Sold],
			        REMOVEFILTERS('Date'),
			        FILTER(
			            ALL( Orders[Order Date] ),
			            YEAR( DATEVALUE( Orders[Order Date] ) ) = SelectedYear - 1
			        )
			    )
			
			RETURN
			DIVIDE( UY1 * 4 + UY2, 5 )
		lineageTag: 9c747b01-3e5b-4d60-ae8a-45efbfc93867

		annotation PBI_FormatHint = {"isGeneralNumber":true}

