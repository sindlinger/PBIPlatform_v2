	measure 'Avg Daily Sales' = DIVIDE([Total Sales], DISTINCTCOUNT('Date'[Date]))
		formatString: R$ #,0.###############;(R$ #,0.###############);R$ #,0.###############
		lineageTag: 4304dc30-572e-487c-a7f9-8aa93b757a06

	measure 'Sales MoM %' =
			
			VAR CurrentMonth = [Total Sales]
			VAR PreviousMonths =
			    CALCULATE ( [Total Sales], DATEADD ( 'Date'[Date], -1, MONTH ) )
			RETURN
			    DIVIDE ( CurrentMonth - PreviousMonths, PreviousMonths )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 4e398f9e-7a70-47a6-b87c-667b2c848547

	measure 'Sales MoM' =
			
			VAR CurrentMonth = [Total Sales]
			VAR PreviousMonths =
			    CALCULATE ( [Total Sales], PREVIOUSMONTH( 'Date'[Date]) )
			RETURN
			    CurrentMonth - PreviousMonths
		lineageTag: abae15d5-75d0-4ef6-969b-098b1ca24f79

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sales Card Subtitle' =
			
			VAR diff = COALESCE([Sales MoM], 0)
			VAR perc = COALESCE([Sales MoM %], 0)
			VAR sign = IF(perc >= 0, "+", "-")
			RETURN
			    sign &
			    FORMAT(ABS(diff) / 1000, "0.0") & "K | " &
			    sign & FORMAT(ABS(perc), "0.0%")
		lineageTag: 6e18fa24-d43c-494b-b952-2a8e7cb593bf

	measure 'Avg Sales' = [Valor Médio por Perícia]
		lineageTag: 30797419-53e9-4f5a-8556-1cbad935cbbb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sales MoM Label' =
			
			VAR diff = COALESCE([Sales MoM], 0)
			VAR perc = COALESCE([Sales MoM %], 0)
			VAR sign = IF(perc >= 0, "+", "-")
			RETURN
			    sign & FORMAT(ABS(perc), "0%")
		lineageTag: 9af65256-ac83-44dc-9287-b2b4e5b11197

	measure 'Sales Color' =
			
			VAR CorContexto =
			    SWITCH(
			        TRUE(),
			        ISINSCOPE(DimPeritos[PeritoLabel]), "#1E88E5",
			        ISINSCOPE(DimComarcas[Comarca]), "#0EA5A4",
			        ISINSCOPE(DimVaras[Juizo]), "#F59E0B",
			        ISINSCOPE(DimEspecialidades[Especialidade]), "#22C55E",
			        BLANK()
			    )
			VAR MediaPeriodo =
			    CALCULATE(
			        AVERAGEX(
			            VALUES('Date'[MonthName]),
			            [Total Sales]
			        ),
			        ALLSELECTED('Date')
			    )
			VAR Atual = [Total Sales]
			RETURN
			    COALESCE(CorContexto, IF(Atual >= MediaPeriodo, "#1E88E5", "#C7D2E2"))
		lineageTag: eb8ce935-040f-4581-ab6d-6e36854bc8b2

	measure 'Annual Avg Line Fixed' =
			
			VAR Visible_Months =
			    ALLSELECTED('Date'[MonthName])  // Lists all months visible in the current filter context
			RETURN
			    AVERAGEX(
			        Visible_Months,             // Iterates over each of those months
			        [Total Sales]               // Averages the [Total Sales] value for each month
			    )
		lineageTag: 21186e28-ffd9-4cb2-9298-c42d2bfeb09e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Sales Total' = DIVIDE([Total Sales], CALCULATE([Total Sales], ALLSELECTED(DimComarcas), ALLSELECTED(DimVaras), ALLSELECTED(DimPeritos), ALLSELECTED(DimEspecialidades)))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 8bb2f26e-68ae-4bf2-8650-314df3e2133c

	measure '% Sales' = [% Sales Total]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: ba407c7b-92fb-4d33-8230-f134833f16f4

	measure 'Label City Sales %' =
			
			SELECTEDVALUE(DimComarcas[Comarca], "Todas as comarcas") & " | " &
			FORMAT([% Sales], "0%")
		lineageTag: 86e5eaa3-9bde-4aa6-b6ae-5ba13a6de0f4

	measure 'Label Bar City Sales %' = FORMAT([% Sales], "0%")  & " | " & FORMAT([Total Sales], "R$ #,##0")
		lineageTag: db159ac3-8f7d-494d-a013-6c62302afd41

	measure 'SMA Sales (N)' =
			
			
			
			VAR Nperiods = 7
			RETURN
			AVERAGEX(
			  DATESINPERIOD( 'Date'[Date], MAX( 'Date'[Date] ), -Nperiods + 1, DAY ),
			  [Total Sales]
			)
		lineageTag: 4816f810-2237-4483-964f-e755abc953d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'StdDev Sales (N)' =
			
			
			
			VAR Nperiods = 7
			RETURN
			STDEVX.P(
			  DATESINPERIOD( 'Date'[Date], MAX( 'Date'[Date] ), -Nperiods + 1, DAY ),
			  CALCULATE( [Total Sales] )
			)
		lineageTag: c1e391b5-7250-4650-825b-a20401389373

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Lower Band (N)' = [SMA Sales (N)] - [StdDev Sales (N)]
		lineageTag: e909730c-b008-4cf3-b25c-9e080f916953

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Upper Band (N)' = [SMA Sales (N)] + [StdDev Sales (N)]
		lineageTag: 4a8b79c8-7735-4b83-991e-8f354776c8f9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

