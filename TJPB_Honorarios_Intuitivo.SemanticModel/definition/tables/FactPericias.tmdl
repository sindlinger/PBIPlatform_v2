table FactPericias
	lineageTag: 5236453a-0009-44f5-95b4-6a46c5c9dc10

	measure 'Qtd Perícias' = COUNTROWS(FactPericias)
		formatString: #,0
		lineageTag: f05aebd2-5b00-4ecd-bb6f-54df3eb19625

	measure 'Valor Arbitrado' = SUM(FactPericias[ValorArbitrado])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: ae18ea0b-2f7b-45a0-bad8-9750d5149b52

	measure 'Valor Adiantado Efetivo' = SUM(FactPericias[ValorAdiantadoEfetivo])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		isHidden
		lineageTag: 59db0e32-0318-4ddf-b1cf-68714d88b18b

	measure 'Saldo a Receber' = SUM(FactPericias[SaldoCalculado])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: 2caac1ba-8976-4277-a822-19001a4cc71f

	measure 'Perícias com Autorização' = CALCULATE([Qtd Perícias], FactPericias[HasAutorizacao] = TRUE())
		formatString: #,0
		isHidden
		lineageTag: 6953b6a1-9e3b-4fbe-935a-756c768bb235

	measure 'Peritos Distintos' =
			CALCULATE(
				DISTINCTCOUNT(FactPericias[PeritoKey]),
				FactPericias[PeritoKey] <> "NOME|SEM PERITO"
			)
		formatString: #,0
		lineageTag: 3268e836-a3c1-46f1-b5b6-99ea1f84ed9b

	measure 'Especialidades Distintas' =
			CALCULATE(
				DISTINCTCOUNT(FactPericias[Especialidade]),
				FactPericias[Especialidade] <> "SEM ESPECIALIDADE"
			)
		formatString: #,0
		lineageTag: f563909d-cd53-4f0f-b130-008245beea42

	measure 'Valor Médio por Perícia' = DIVIDE([Valor Arbitrado], [Qtd Perícias])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: 9f0bbf7d-7831-4284-b478-0f71f5e85605

	measure 'Saldo Médio por Perícia' = DIVIDE([Saldo a Receber], [Qtd Perícias])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: bb856ecd-2188-478f-8ce6-1f1e7778ec92

	measure 'Backlog (Qtd pendente)' = CALCULATE([Qtd Perícias], FactPericias[StatusFluxo] <> "Com Adiantamento")
		formatString: #,0
		lineageTag: 63f7d45e-8382-49ce-b0f5-e676f381f5ca

	measure 'Backlog (Saldo pendente)' = CALCULATE([Saldo a Receber], FactPericias[StatusFluxo] <> "Com Adiantamento")
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: 9626f02c-7a02-4f26-bd32-27b3f5d33b6d

	measure 'Ticket Médio' = DIVIDE([Valor Arbitrado], [Qtd Perícias])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: 4d9adfca-8f00-4c53-b5d4-3ebf3e5adf9f

	measure 'Participação %' =
			DIVIDE(
				[Valor Arbitrado],
				CALCULATE(
					[Valor Arbitrado],
					ALLSELECTED(DimComarcas),
					ALLSELECTED(DimVaras),
					ALLSELECTED(DimEspecialidades),
					ALLSELECTED(DimPeritos)
				)
			)
		formatString: 0.00%
		lineageTag: 284818cc-b43f-4f1c-acf9-c67f86cf5ace

	measure 'Top 10 Peritos (Valor)' =
			CALCULATE(
				[Valor Arbitrado],
				TOPN(
					10,
					ALLSELECTED(DimPeritos[PeritoLabel]),
					[Valor Arbitrado],
					DESC
				)
			)
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: 2f9a8a56-33f3-4cb6-a0ad-9fef62908718

	measure 'Participação Top 10 Peritos %' = DIVIDE([Top 10 Peritos (Valor)], [Valor Arbitrado])
		formatString: 0.00%
		lineageTag: 0ec90ad2-44bf-4693-8ad5-c914a2003cd1

	measure 'Linhas SEM PERITO' = CALCULATE(COUNTROWS(FactPericias), FactPericias[PeritoLabel] = "SEM PERITO")
		formatString: #,0
		lineageTag: a571c509-58a4-47d5-939d-f3d4f11f80be

	measure 'Linhas SEM COMARCA' = CALCULATE(COUNTROWS(FactPericias), FactPericias[Comarca] = "SEM COMARCA")
		formatString: #,0
		lineageTag: bfd3b25a-b810-4f72-a9b5-a97f568dc6dd

	measure 'Linhas Valor Arbitrado Nulo/Zero' =
			CALCULATE(
				COUNTROWS(FactPericias),
				FILTER(
					FactPericias,
					ISBLANK(FactPericias[ValorArbitrado]) || FactPericias[ValorArbitrado] <= 0
				)
			)
		formatString: #,0
		lineageTag: b615f60d-76ac-4130-b4ea-f07fcf41bc4c

	measure 'Comarca Selecionada' = SELECTEDVALUE(DimComarcas[Comarca], "Todas as comarcas")
		lineageTag: 2fd9b08f-9c38-4f6f-9fd1-a929f6624e8f

	measure 'Peritos na Comarca' =
			CALCULATE(
				DISTINCTCOUNT(FactPericias[PeritoKey]),
				FactPericias[PeritoKey] <> "NOME|SEM PERITO"
			)
		formatString: #,0
		lineageTag: 5f52e7b2-2d62-4ead-9a89-09704a34fb68

	measure 'Varas na Comarca' = DISTINCTCOUNT(FactPericias[Juizo])
		formatString: #,0
		lineageTag: 6a774a2f-1019-4fb5-9eb4-f248258b41d6

	measure 'Especialidades na Comarca' = DISTINCTCOUNT(FactPericias[Especialidade])
		formatString: #,0
		lineageTag: d9a8df12-39f5-4f05-b8d2-b0c4f3ecf781

	measure 'Quem Recebe Mais (Valor)' =
			VAR TopPerito =
				TOPN(
					1,
					SUMMARIZE(
						FILTER(FactPericias, FactPericias[PeritoLabel] <> "SEM PERITO"),
						FactPericias[PeritoLabel],
						"ValorPerito", [Valor Arbitrado]
					),
					[ValorPerito], DESC,
					FactPericias[PeritoLabel], ASC
				)
			RETURN
				MAXX(TopPerito, [ValorPerito])
		formatString: R$ #,##0.00;R$ -#,##0.00;R$ 0.00
		lineageTag: fd72f5ee-4e46-4df8-b31f-9f6e63d4153e

	measure 'Campeão da Comarca' =
			VAR TopPerito =
				TOPN(
					1,
					SUMMARIZE(
						FILTER(FactPericias, FactPericias[PeritoLabel] <> "SEM PERITO"),
						FactPericias[PeritoLabel],
						"ValorPerito", [Valor Arbitrado]
					),
					[ValorPerito], DESC,
					FactPericias[PeritoLabel], ASC
				)
			VAR Nome = MAXX(TopPerito, FactPericias[PeritoLabel])
			VAR Valor = MAXX(TopPerito, [ValorPerito])
			RETURN
				IF(ISBLANK(Valor), BLANK(), Nome & " | " & FORMAT(Valor, "R$ #,##0.00"))
		lineageTag: f73cfd80-8f5e-4f74-a14e-b5b3bf315151

	measure 'Vara Campeã (Comarca)' =
			VAR TopVara =
				TOPN(
					1,
					SUMMARIZE(
						FactPericias,
						FactPericias[JuizoExibicao],
						"ValorVara", [Valor Arbitrado]
					),
					[ValorVara], DESC,
					FactPericias[JuizoExibicao], ASC
				)
			RETURN
				MAXX(TopVara, FactPericias[JuizoExibicao])
		lineageTag: 81280988-1aaf-44ad-bf0e-5093898bc068

	measure 'Especialidades Top 5 (Comarca)' =
			VAR TopEsp =
				TOPN(
					5,
					SUMMARIZE(
						FactPericias,
						FactPericias[EspecialidadeExibicao],
						"ValorEsp", [Valor Arbitrado]
					),
					[ValorEsp], DESC,
					FactPericias[EspecialidadeExibicao], ASC
				)
			RETURN
				CONCATENATEX(TopEsp, FactPericias[EspecialidadeExibicao], ", ")
		lineageTag: c4df74de-6524-4007-be8e-f12f9b40d422

	measure 'Peritos Top 5 (Comarca)' =
			VAR TopPeritos =
				TOPN(
					5,
					SUMMARIZE(
						FILTER(FactPericias, FactPericias[PeritoLabel] <> "SEM PERITO"),
						FactPericias[PeritoLabel],
						"ValorPerito", [Valor Arbitrado]
					),
					[ValorPerito], DESC,
					FactPericias[PeritoLabel], ASC
				)
			RETURN
				CONCATENATEX(TopPeritos, FactPericias[PeritoLabel], ", ")
		lineageTag: 89c64f51-7ca8-4e51-8091-2e2743f4d1ce

