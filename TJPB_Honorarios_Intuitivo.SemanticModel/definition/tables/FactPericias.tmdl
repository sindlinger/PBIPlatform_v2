		sourceColumn: PeritoLabel

		annotation SummarizationSetBy = Automatic

	partition FactPericias = m
		mode: import
		source =
				let
				    ExcelPath0 = try Text.From(ExcelPath) otherwise "",
				    ExcelPath1 = Text.Clean(Text.Trim(ExcelPath0)),
				    ExcelPath2 = Text.Replace(Text.Replace(ExcelPath1, Character.FromNumber(34), ""), "'", ""),
				    ExcelPathFinal = Text.Replace(ExcelPath2, "/", Character.FromNumber(92)),
				    SheetName0 = try Text.From(SheetName) otherwise "",
				    SheetName1 = Text.Clean(Text.Trim(SheetName0)),
				    SheetNameFinal = if SheetName1 = "" then "Dados (Tabela)" else SheetName1,
				
				    Source = Excel.Workbook(File.Contents(ExcelPathFinal), null, true),
				    RawData =
				        let
				            BySheet = try Source{[Item = SheetNameFinal, Kind = "Sheet"]}[Data] otherwise null,
				            ByTable = if BySheet <> null then null else (try Source{[Item = SheetNameFinal, Kind = "Table"]}[Data] otherwise null),
				            Fallback = if BySheet <> null then BySheet else if ByTable <> null then ByTable else Source{[Item = "Dados (Tabela)", Kind = "Sheet"]}[Data]
				        in
				            Fallback,
				
				    #"Skip Top Rows" = Table.Skip(RawData, 2),
				    #"Promoted Headers" = Table.PromoteHeaders(#"Skip Top Rows", [PromoteAllScalars = true]),
				
				    #"Renamed Columns" =
				        Table.RenameColumns(
				            #"Promoted Headers",
				            {
				                {"Nº DE PERÍCIAS", "NumeroPericia"},
				                {"DATA DA REQUISIÇÃO", "DataRequisicao"},
				                {"PROCESSO ADMIN. Nº", "ProcessoAdminNumero"},
				                {"JUÍZO", "Juizo"},
				                {"COMARCA", "Comarca"},
				                {"PROCESSO Nº", "ProcessoNumero"},
				                {"PROMOVENTE", "Promovente"},
				                {"PROMOVIDO", "Promovido"},
				                {"PERITO", "PeritoNome"},
				                {"CPF/CNJP", "CpfCnpjRaw"},
				                {"CPF/CNPJ", "CpfCnpjRaw"},
				                {"ESPECIALIDADE", "Especialidade"},
				                {"ESPÉCIE DE PERÍCIA", "EspeciePericia"},
				                {"Fator", "Fator"},
				                {"Valor Tabelado Anexo I - Tabela I", "ValorTabelado"},
				                {"VALOR TABELADO", "ValorTabelado"},
				                {"VALOR ARBITRADO", "ValorArbitrado"},
				                {"CHECAGEM", "Checagem"},
				                {"DATA ADIANTAMENTO", "DataAdiantamento"},
				                {"R$", "ValorAdiantado"},
				                {"%", "PercentualAdiantado"},
				                {"CHECAGEM ADIATAMENTO", "ChecagemAdiantamento"},
				                {"CHECAGEM ADIANTAMENTO", "ChecagemAdiantamento"},
				                {"Data da Autorização da Despesa", "DataAutorizacaoDespesa"},
				                {"DATA DA AUTORIZAÇÃO DA DESPESA", "DataAutorizacaoDespesa"},
				                {"SALDO A RECEBER", "SaldoAReceber"},
				                {"SALDO FINAL", "SaldoFinal"}
				            },
				            MissingField.Ignore
				        ),
				
				    BaseCols = {
				        "NumeroPericia","DataRequisicao","ProcessoAdminNumero","Juizo","Comarca","ProcessoNumero",
				        "Promovente","Promovido","PeritoNome","CpfCnpjRaw","Especialidade","EspeciePericia",
				        "Fator","ValorTabelado","ValorArbitrado","Checagem","DataAdiantamento","ValorAdiantado","PercentualAdiantado",
				        "ChecagemAdiantamento","DataAutorizacaoDespesa","SaldoAReceber","SaldoFinal"
				    },
				    #"With All Base Cols" =
				        List.Accumulate(
				            BaseCols,
				            #"Renamed Columns",
				            (state as table, col as text) =>
				                if List.Contains(Table.ColumnNames(state), col) then state else Table.AddColumn(state, col, each null)
				        ),
				    #"Base Selected" = Table.SelectColumns(#"With All Base Cols", BaseCols, MissingField.UseNull),
				
				    ToText = (v as any) as nullable text =>
				        let t = if v = null then null else Text.Trim(Text.Clean(Text.From(v)))
				        in if t = "" then null else t,
				
				    ToDate = (v as any) as nullable date =>
				        let
				            d0 = try Date.From(v) otherwise null,
				            d1 =
				                if d0 <> null then d0
				                else
				                    let
				                        s0 = ToText(v),
				                        s1 = if s0 = null then null else Text.Replace(s0, "-", "/"),
				                        d2 = try Date.FromText(s1, "pt-BR") otherwise null
				                    in
				                        d2
				        in
				            d1,
				
				    ToNumber = (v as any) as nullable number =>
				        let
				            n0 = try Number.From(v) otherwise null,
				            n1 =
				                if n0 <> null then n0
				                else
				                    let
				                        s0 = ToText(v),
				                        s1 = if s0 = null then null else Text.Replace(Text.Replace(Text.Replace(Text.Replace(s0, "R$", ""), " ", ""), ".", ""), ",", "."),
				                        n2 = try Number.FromText(s1, "en-US") otherwise null
				                    in
				                        n2
				        in
				            n1,
				
				    ToPercentFraction = (v as any) as nullable number =>
				        let
				            n = ToNumber(v)
				        in
				            if n = null then null else if n > 1 then n / 100 else n,
				
				    NormalizeKey = (v as nullable text) as text =>
				        let
				            t0 = if v = null then "SEM PERITO" else Text.Upper(v),
				            t1 = Text.Select(t0, List.Combine({{"A".."Z"}, {"0".."9"}, {" "}})),
				            parts = List.Select(Text.Split(Text.Trim(t1), " "), each _ <> ""),
				            t2 = if List.Count(parts) = 0 then "SEM PERITO" else Text.Combine(parts, " ")
				        in
				            t2,
				
				    ToDisplay = (v as any, missingLabel as text) as text =>
				        let
				            t0 = ToText(v),
				            t1 = if t0 = null then missingLabel else t0,
				            u = Text.Upper(t1)
				        in
				            if Text.StartsWith(u, "SEM ") then u else Text.Proper(Text.Lower(t1)),
				
				    MaskDoc = (doc as nullable text) as nullable text =>
				        if doc = null or Text.Length(doc) < 4 then null else "******" & Text.End(doc, 4),
				
				    #"Text Cleaned" =
				        Table.TransformColumns(
				            #"Base Selected",
				            {
				                {"NumeroPericia", each ToText(_), type nullable text},
				                {"ProcessoAdminNumero", each ToText(_), type nullable text},
				                {"Juizo", each ToText(_), type nullable text},
				                {"Comarca", each ToText(_), type nullable text},
				                {"ProcessoNumero", each ToText(_), type nullable text},
				                {"Promovente", each ToText(_), type nullable text},
				                {"Promovido", each ToText(_), type nullable text},
				                {"PeritoNome", each ToText(_), type nullable text},
				                {"CpfCnpjRaw", each ToText(_), type nullable text},
				                {"Especialidade", each ToText(_), type nullable text},
				                {"EspeciePericia", each ToText(_), type nullable text},
				                {"Checagem", each ToText(_), type nullable text},
				                {"ChecagemAdiantamento", each ToText(_), type nullable text}
				            }
				        ),
				
				    #"Converted Types" =
				        Table.TransformColumns(
				            #"Text Cleaned",
				            {
				                {"DataRequisicao", each ToDate(_), type nullable date},
				                {"DataAdiantamento", each ToDate(_), type nullable date},
				                {"DataAutorizacaoDespesa", each ToDate(_), type nullable date},
				                {"Fator", each ToNumber(_), type nullable number},
				                {"ValorTabelado", each ToNumber(_), type nullable number},
				                {"ValorArbitrado", each ToNumber(_), type nullable number},
				                {"ValorAdiantado", each ToNumber(_), type nullable number},
				                {"PercentualAdiantado", each ToPercentFraction(_), type nullable number},
				                {"SaldoAReceber", each ToNumber(_), type nullable number},
				                {"SaldoFinal", each ToNumber(_), type nullable number}
				            }
				        ),
				
				    #"Filtered Rows" =
				        Table.SelectRows(
				            #"Converted Types",
				            each
				                [DataRequisicao] <> null and
				                [ValorArbitrado] <> null and
				                [PeritoNome] <> null and
				                [Comarca] <> null and
				                [Juizo] <> null and
				                [Especialidade] <> null and
				                [EspeciePericia] <> null
				        ),
				
				    #"Added PeritoNomeExibicao" = Table.AddColumn(#"Filtered Rows", "PeritoNomeExibicao", each ToDisplay([PeritoNome], "SEM PERITO"), type text),
				    #"Added JuizoExibicao" = Table.AddColumn(#"Added PeritoNomeExibicao", "JuizoExibicao", each ToDisplay([Juizo], "SEM JUÍZO"), type text),
				    #"Added ComarcaExibicao" = Table.AddColumn(#"Added JuizoExibicao", "ComarcaExibicao", each ToDisplay([Comarca], "SEM COMARCA"), type text),
				    #"Added EspecialidadeExibicao" = Table.AddColumn(#"Added ComarcaExibicao", "EspecialidadeExibicao", each ToDisplay([Especialidade], "SEM ESPECIALIDADE"), type text),
				    #"Added CpfCnpjDigits" = Table.AddColumn(#"Added EspecialidadeExibicao", "CpfCnpjDigits", each if [CpfCnpjRaw] = null then null else Text.Select([CpfCnpjRaw], {"0".."9"}), type nullable text),
				    #"Added DocValid" = Table.AddColumn(#"Added CpfCnpjDigits", "DocValid", each let d = [CpfCnpjDigits] in if d = null then null else if Text.Length(d) = 11 or Text.Length(d) = 14 then d else null, type nullable text),
				    #"Added DocFinal" = Table.AddColumn(#"Added DocValid", "DocFinal", each [DocValid], type nullable text),
				    #"Added CpfCnpjMascarado" = Table.AddColumn(#"Added DocFinal", "CpfCnpjMascarado", each MaskDoc([DocFinal]), type nullable text),
				    #"Added NomeNorm" = Table.AddColumn(#"Added CpfCnpjMascarado", "NomeNorm", each NormalizeKey([PeritoNomeExibicao]), type text),
				    #"Added PeritoKey" = Table.AddColumn(#"Added NomeNorm", "PeritoKey", each if [DocFinal] <> null and [DocFinal] <> "" then "DOC|" & [DocFinal] else "NOME|" & [NomeNorm], type text),
				    #"Added PeritoLabel" = Table.AddColumn(#"Added PeritoKey", "PeritoLabel", each if [CpfCnpjMascarado] <> null then [PeritoNomeExibicao] & " (" & [CpfCnpjMascarado] & ")" else [PeritoNomeExibicao], type text),
				    #"Added QtdDocsDistintos" = Table.AddColumn(#"Added PeritoLabel", "QtdDocsDistintos", each if [DocFinal] = null then 0 else 1, Int64.Type),
				    #"Added DocsMascaradosConcatenados" = Table.AddColumn(#"Added QtdDocsDistintos", "DocsMascaradosConcatenados", each [CpfCnpjMascarado], type nullable text),
				    #"Added NomeComDocsMultiplos" = Table.AddColumn(#"Added DocsMascaradosConcatenados", "NomeComDocsMultiplos", each "NAO", type text),
				    #"Added HasAutorizacao" = Table.AddColumn(#"Added NomeComDocsMultiplos", "HasAutorizacao", each [DataAutorizacaoDespesa] <> null, type logical),
				    #"Added HasAdiantamento" = Table.AddColumn(#"Added HasAutorizacao", "HasAdiantamento", each [DataAdiantamento] <> null or [ValorAdiantado] <> null or [PercentualAdiantado] <> null, type logical),
				    #"Added ValorAdiantadoEfetivo" = Table.AddColumn(#"Added HasAdiantamento", "ValorAdiantadoEfetivo", each if [ValorAdiantado] <> null then [ValorAdiantado] else if [PercentualAdiantado] <> null and [ValorArbitrado] <> null then [PercentualAdiantado] * [ValorArbitrado] else null, type nullable number),
				    #"Added SaldoCalculado" = Table.AddColumn(#"Added ValorAdiantadoEfetivo", "SaldoCalculado", each if [SaldoAReceber] <> null then [SaldoAReceber] else if [ValorArbitrado] <> null and [ValorAdiantadoEfetivo] <> null then [ValorArbitrado] - [ValorAdiantadoEfetivo] else [ValorArbitrado], type nullable number),
				    Today = Date.From(DateTime.LocalNow()),
				    #"Added DiasDesdeRequisicao" = Table.AddColumn(#"Added SaldoCalculado", "DiasDesdeRequisicao", each if [DataRequisicao] = null then null else Duration.Days(Today - [DataRequisicao]), Int64.Type),
				    #"Added DiasReqAteAutorizacao" = Table.AddColumn(#"Added DiasDesdeRequisicao", "DiasReqAteAutorizacao", each if [DataRequisicao] = null or [DataAutorizacaoDespesa] = null then null else Duration.Days([DataAutorizacaoDespesa] - [DataRequisicao]), Int64.Type),
				    #"Added DiasAutAteAdiantamento" = Table.AddColumn(#"Added DiasReqAteAutorizacao", "DiasAutAteAdiantamento", each if [DataAutorizacaoDespesa] = null or [DataAdiantamento] = null then null else Duration.Days([DataAdiantamento] - [DataAutorizacaoDespesa]), Int64.Type),
				    #"Added AgingFaixa" = Table.AddColumn(#"Added DiasAutAteAdiantamento", "AgingFaixa", each let d = [DiasDesdeRequisicao] in if d = null then null else if d <= 7 then "0-7" else if d <= 15 then "8-15" else if d <= 30 then "16-30" else if d <= 60 then "31-60" else if d <= 90 then "61-90" else "90+", type nullable text),
				    #"Added StatusFluxo" = Table.AddColumn(#"Added AgingFaixa", "StatusFluxo", each if [HasAutorizacao] = false then "Pendente de Autorização" else if [HasAdiantamento] = false then "Autorizado, pendente de Adiantamento" else "Com Adiantamento", type text),
				
				    FinalCols = {
				        "PeritoNome","EspeciePericia","Fator","NumeroPericia","DataRequisicao","ProcessoAdminNumero","Juizo","Comarca",
				        "ProcessoNumero","Promovente","Promovido","Especialidade","ValorTabelado","ValorArbitrado","Checagem","DataAdiantamento",
				        "ValorAdiantado","PercentualAdiantado","ChecagemAdiantamento","DataAutorizacaoDespesa","SaldoAReceber","SaldoFinal",
				        "CpfCnpjDigits","CpfCnpjMascarado","HasAutorizacao","HasAdiantamento","ValorAdiantadoEfetivo","SaldoCalculado",
				        "DiasDesdeRequisicao","AgingFaixa","DiasReqAteAutorizacao","DiasAutAteAdiantamento","StatusFluxo","PeritoNomeExibicao",
				        "JuizoExibicao","ComarcaExibicao","EspecialidadeExibicao","PeritoKey","NomeNorm","DocValid","DocFinal","QtdDocsDistintos",
				        "DocsMascaradosConcatenados","NomeComDocsMultiplos","PeritoLabel"
				    },
				    Final = Table.SelectColumns(#"Added StatusFluxo", FinalCols, MissingField.UseNull)
				in
				    Final

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

