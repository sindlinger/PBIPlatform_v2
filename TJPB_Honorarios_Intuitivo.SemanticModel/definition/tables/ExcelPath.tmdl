table ExcelPath
	isHidden
	lineageTag: 176a116f-16b1-42cc-a89e-ab2120316d88

	column ExcelPath
		dataType: string
		lineageTag: 1504b5c2-6459-43fb-8e30-b9b3b372c4f9
		summarizeBy: none
		sourceColumn: ExcelPath

		annotation SummarizationSetBy = Automatic

	partition ExcelPath = m
		mode: import
		source =
				let
				    // Coloque aqui o caminho COMPLETO (Windows)
				    p0 = "C:\git\PBIPlatform_v2\EstatisticasPeritos.xlsx",
				
				    // limpa espaços/controles e remove aspas (") e apóstrofo (')
				    p1 = Text.Clean(Text.Trim(p0)),
				    p2 = Text.Replace(p1, Character.FromNumber(34), ""),   // remove "
				    p3 = Text.Replace(p2, "'", ""),                        // remove '
				    p4 = Text.Replace(p3, Character.FromNumber(160), " "), // remove NBSP
				    p  = Text.Trim(p4)
				in
				    p meta [IsParameterQuery = true, Type = "Text", IsParameterQueryRequired = true]

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Text

