				    #"Added Order Priority" = Table.AddColumn(#"Added Shipping Cost", "Order Priority", each [StatusFluxo], type text),
				    #"Selected Columns" = Table.SelectColumns(#"Added Order Priority", {"Row ID", "Order ID", "Order Date", "Ship Date", "Ship Mode", "Customer ID", "Customer Name", "Segment", "Postal Code", "City", "State", "State Mapa", "Country", "Region", "Market", "Product ID", "Category", "Sub-Category", "Product Name", "Sales", "Quantity", "Discount", "Profit", "Shipping Cost", "Order Priority"})
				in
				    #"Selected Columns"

