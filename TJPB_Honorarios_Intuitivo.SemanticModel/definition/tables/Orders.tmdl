	partition Orders = m
		mode: import
		source =
				let
				    Source = FactPericias,
				    Keep = Table.SelectColumns(Source, {"NumeroPericia", "DataRequisicao", "CpfCnpjDigits", "PeritoNomeExibicao", "EspeciePericia", "JuizoExibicao", "ComarcaExibicao", "EspecialidadeExibicao", "ValorArbitrado", "SaldoCalculado", "StatusFluxo"}, MissingField.UseNull),
				    Clean = Table.TransformColumns(Keep, {
				        {"NumeroPericia", each if _ = null then null else Text.Trim(Text.From(_)), type nullable text},
				        {"CpfCnpjDigits", each if _ = null then null else Text.Trim(Text.From(_)), type nullable text},
				        {"PeritoNomeExibicao", each if _ = null or Text.Trim(Text.From(_)) = "" then "SEM PERITO" else Text.Trim(Text.From(_)), type text},
				        {"EspeciePericia", each if _ = null or Text.Trim(Text.From(_)) = "" then "SEM ESPĂCIE" else Text.Trim(Text.From(_)), type text},
				        {"JuizoExibicao", each if _ = null or Text.Trim(Text.From(_)) = "" then "SEM JUĂZO" else Text.Trim(Text.From(_)), type text},
				        {"ComarcaExibicao", each if _ = null or Text.Trim(Text.From(_)) = "" then "SEM COMARCA" else Text.Trim(Text.From(_)), type text},
				        {"EspecialidadeExibicao", each if _ = null or Text.Trim(Text.From(_)) = "" then "SEM ESPECIALIDADE" else Text.Trim(Text.From(_)), type text}
				    }),
				    NormalizeComarcaMapa = (value as any) as nullable text =>
				        let
				            StripAccents = (textValue as nullable text) as nullable text =>
				                if textValue = null then
				                    null
				                else
				                    let
				                        Replacements = {
				                            {"Ă", "A"}, {"Ă", "A"}, {"Ă", "A"}, {"Ă", "A"}, {"Ă", "A"},
				                            {"ĂĄ", "a"}, {"Ă ", "a"}, {"Ăą", "a"}, {"ĂŁ", "a"}, {"Ă€", "a"},
				                            {"Ă", "E"}, {"Ă", "E"}, {"Ă", "E"}, {"Ă", "E"},
				                            {"Ă©", "e"}, {"Ăš", "e"}, {"ĂȘ", "e"}, {"Ă«", "e"},
				                            {"Ă", "I"}, {"Ă", "I"}, {"Ă", "I"}, {"Ă", "I"},
				                            {"Ă­", "i"}, {"ĂŹ", "i"}, {"Ăź", "i"}, {"ĂŻ", "i"},
				                            {"Ă", "O"}, {"Ă", "O"}, {"Ă", "O"}, {"Ă", "O"}, {"Ă", "O"},
				                            {"Ăł", "o"}, {"ĂČ", "o"}, {"ĂŽ", "o"}, {"Ă”", "o"}, {"Ă¶", "o"},
				                            {"Ă", "U"}, {"Ă", "U"}, {"Ă", "U"}, {"Ă", "U"},
				                            {"Ăș", "u"}, {"Ăč", "u"}, {"Ă»", "u"}, {"ĂŒ", "u"},
				                            {"Ă", "C"}, {"Ă§", "c"},
				                            {"Ă", "N"}, {"Ă±", "n"}
				                        },
				                        Stripped = List.Accumulate(Replacements, textValue, (state as text, pair as list) => Text.Replace(state, pair{0}, pair{1}))
				                    in
				                        Stripped,
				            NormalizeKey = (textValue as nullable text) as nullable text =>
				                if textValue = null then
				                    null
				                else
				                    let
				                        Upper = Text.Upper(StripAccents(Text.Trim(textValue))),
				                        KeepChars = Text.Select(Upper, List.Combine({{"A".."Z"}, {"0".."9"}, {" "}})),
				                        Parts = List.Select(Text.Split(KeepChars, " "), each _ <> ""),
				                        Key = if List.Count(Parts) = 0 then null else Text.Combine(Parts, " ")
				                    in
				                        Key,
				            OfficialComarcaByKey = [
				                #"AGUA BRANCA" = "Ăgua Branca",
				                #"ALAGOA GRANDE" = "Alagoa Grande",
				                #"ALAGOA NOVA" = "Alagoa Nova",
				                #"ALAGOINHA" = "Alagoinha",
				                #"ALHANDRA" = "Alhandra",
				                #"ARACAGI" = "AraĂ§agi",
				                #"ARARA" = "Arara",
				                #"ARARUNA" = "Araruna",
				                #"AREIA" = "Areia",
				                #"AROEIRAS" = "Aroeiras",
				                #"BANANEIRAS" = "Bananeiras",
				                #"BARRA DE SANTA ROSA" = "Barra de Santa Rosa",
				                #"BAYEUX" = "Bayeux",
				                #"BELEM" = "BelĂ©m",
				                #"BONITO DE SANTA FE" = "Bonito de Santa FĂ©",
				                #"BOQUEIRAO" = "BoqueirĂŁo",
				                #"BREJO DO CRUZ" = "Brejo do Cruz",
				                #"CAAPORA" = "CaaporĂŁ",
				                #"CABACEIRAS" = "Cabaceiras",
				                #"CABEDELO" = "Cabedelo",
				                #"CACIMBA DE DENTRO" = "Cacimba de Dentro",
				                #"CAICARA" = "CaiĂ§ara",
				                #"CAJAZEIRAS" = "Cajazeiras",
				                #"CAMPINA GRANDE" = "Campina Grande",
				                #"CATOLE DO ROCHA" = "CatolĂ© do Rocha",
				                #"CONCEICAO" = "ConceiĂ§ĂŁo",
				                #"CONDE" = "Conde",
				                #"COREMAS" = "Coremas",
				                #"CRUZ DO ESPIRITO SANTO" = "Cruz do EspĂ­rito Santo",
				                #"CUITE" = "CuitĂ©",
				                #"ESPERANCA" = "EsperanĂ§a",
				                #"GUARABIRA" = "Guarabira",
				                #"GURINHEM" = "GurinhĂ©m",
				                #"INGA" = "IngĂĄ",
				                #"ITABAIANA" = "Itabaiana",
				                #"ITAPORANGA" = "Itaporanga",
				                #"JACARAU" = "JacaraĂș",
				                #"JOAO PESSOA" = "JoĂŁo Pessoa",
				                #"JUAZEIRINHO" = "Juazeirinho",
				                #"LUCENA" = "Lucena",
				                #"MALTA" = "Malta",
				                #"MAMANGUAPE" = "Mamanguape",
				                #"MARI" = "Mari",
				                #"MONTEIRO" = "Monteiro",
				                #"PATOS" = "Patos",
				                #"PAULISTA" = "Paulista",
				                #"PEDRAS DE FOGO" = "Pedras de Fogo",
				                #"PIANCO" = "PiancĂł",
				                #"PICUI" = "PicuĂ­",
				                #"PILAR" = "Pilar",
				                #"PILOES" = "PilĂ”es",
				                #"PIRPIRITUBA" = "Pirpirituba",
				                #"POCINHOS" = "Pocinhos",
				                #"POMBAL" = "Pombal",
				                #"PRATA" = "Prata",
				                #"PRINCESA ISABEL" = "Princesa Isabel",
				                #"QUEIMADAS" = "Queimadas",
				                #"REMIGIO" = "RemĂ­gio",
				                #"RIO TINTO" = "Rio Tinto",
				                #"SANTA LUZIA" = "Santa Luzia",
				                #"SANTA RITA" = "Santa Rita",
				                #"SANTANA DOS GARROTES" = "Santana dos Garrotes",
				                #"SAO BENTO" = "SĂŁo Bento",
				                #"SAO JOAO DO CARIRI" = "SĂŁo JoĂŁo do Cariri",
				                #"SAO JOAO DO RIO DO PEIXE" = "SĂŁo JoĂŁo do Rio do Peixe",
				                #"SAO JOSE DA LAGOA TAPADA" = "SĂŁo JosĂ© da Lagoa Tapada",
				                #"SAO JOSE DE PIRANHAS" = "SĂŁo JosĂ© de Piranhas",
				                #"SAO MAMEDE" = "SĂŁo Mamede",
				                #"SAPE" = "SapĂ©",
				                #"SERRA BRANCA" = "Serra Branca",
				                #"SERRARIA" = "Serraria",
				                #"SOLANEA" = "SolĂąnea",
				                #"SOLEDADE" = "Soledade",
				                #"SOUSA" = "Sousa",
				                #"SUME" = "SumĂ©",
				                #"TAPEROA" = "TaperoĂĄ",
				                #"TEIXEIRA" = "Teixeira",
				                #"UIRAUNA" = "UiraĂșna",
				                #"UMBUZEIRO" = "Umbuzeiro"
				            ],
				            AliasToComarcaKey = [
				                #"BAYEUX E SANTA RITA" = "SANTA RITA",
				                #"PRINCESA ISABEL E AGUA BRANCA" = "PRINCESA ISABEL",
				                #"LITORAL SUL" = "ALHANDRA",
				                #"COMARCA INT PRIC ISABEL E AGUA BRANCA" = "PRINCESA ISABEL",
				                #"COMARCAS INTEGRADAS DO LITORAL SUL" = "ALHANDRA",
				                #"SAO JOSE DE LAGOA TAPADA" = "SAO JOSE DA LAGOA TAPADA"
				            ],
				            Base = if value = null then null else Text.Trim(Text.From(value)),
				            UpperBase = if Base = null then null else Text.Upper(Base),
				            WithoutPrefix =
				                if UpperBase = null then null
				                else if Text.StartsWith(UpperBase, "COMARCA INTEGRADA DE ") then Text.Trim(Text.Range(Base, Text.Length("Comarca Integrada de ")))
				                else if Text.StartsWith(UpperBase, "COMARCA INTEGRADA DA ") then Text.Trim(Text.Range(Base, Text.Length("Comarca Integrada da ")))
				                else if Text.StartsWith(UpperBase, "COMARCA INTEGRADA DO ") then Text.Trim(Text.Range(Base, Text.Length("Comarca Integrada do ")))
				                else if Text.StartsWith(UpperBase, "COMARCA DE ") then Text.Trim(Text.Range(Base, Text.Length("Comarca de ")))
				                else if Text.StartsWith(UpperBase, "COMARCA DA ") then Text.Trim(Text.Range(Base, Text.Length("Comarca da ")))
				                else if Text.StartsWith(UpperBase, "COMARCA DO ") then Text.Trim(Text.Range(Base, Text.Length("Comarca do ")))
				                else Base,
				            WithoutUf1 = if WithoutPrefix = null then null else Text.Replace(WithoutPrefix, "/PB", ""),
				            WithoutUf2 = if WithoutUf1 = null then null else Text.Replace(WithoutUf1, "- PB", ""),
				            WithoutUf3 = if WithoutUf2 = null then null else Text.Replace(WithoutUf2, "(PB)", ""),
				            KeyRaw = NormalizeKey(WithoutUf3),
				            KeyFinal = if KeyRaw <> null and Record.HasFields(AliasToComarcaKey, KeyRaw) then Record.Field(AliasToComarcaKey, KeyRaw) else KeyRaw,
				            Canonical = if KeyFinal = null then null else Record.FieldOrDefault(OfficialComarcaByKey, KeyFinal, null)
				        in
				            Canonical,
				    Filtered = Table.SelectRows(Clean, each [DataRequisicao] <> null and [ValorArbitrado] <> null),
				    #"Added Index" = Table.AddIndexColumn(Filtered, "Row ID", 1, 1, Int64.Type),
				    #"Added Order ID" = Table.AddColumn(#"Added Index", "Order ID", each if [NumeroPericia] <> null and [NumeroPericia] <> "" then [NumeroPericia] else Text.From([#"Row ID"]), type text),
				    #"Added Order Date" = Table.AddColumn(#"Added Order ID", "Order Date", each Date.From([DataRequisicao]), type date),
				    #"Added Ship Date" = Table.AddColumn(#"Added Order Date", "Ship Date", each Date.From([DataRequisicao]), type date),
				    #"Added Ship Mode" = Table.AddColumn(#"Added Ship Date", "Ship Mode", each let v = [ValorArbitrado] in if v = null then null else if v < 300 then "AtĂ© R$ 300" else if v < 370 then "R$ 300 - 369" else if v < 450 then "R$ 370 - 449" else if v < 1000 then "R$ 450 - 999" else "R$ 1.000+", type text),
				    #"Added Customer ID" = Table.AddColumn(#"Added Ship Mode", "Customer ID", each [CpfCnpjDigits], type text),
				    #"Added Customer Name" = Table.AddColumn(#"Added Customer ID", "Customer Name", each [PeritoNomeExibicao], type text),
				    #"Added Segment" = Table.AddColumn(#"Added Customer Name", "Segment", each [EspecialidadeExibicao], type text),
				    #"Added Postal Code" = Table.AddColumn(#"Added Segment", "Postal Code", each null, Int64.Type),
				    #"Added City" = Table.AddColumn(#"Added Postal Code", "City", each [JuizoExibicao], type text),
				    #"Added State" = Table.AddColumn(#"Added City", "State", each [ComarcaExibicao], type text),
				    #"Added State Mapa" = Table.AddColumn(#"Added State", "State Mapa", each NormalizeComarcaMapa([ComarcaExibicao]), type nullable text),
				    #"Added Country" = Table.AddColumn(#"Added State Mapa", "Country", each "Brasil", type text),
				    #"Added Region" = Table.AddColumn(#"Added Country", "Region", each [ComarcaExibicao], type text),
