table DimVaras
	lineageTag: 7e7f68f1-506e-475b-9a84-0b1c531fe4a2

	column Juizo
		dataType: string
		lineageTag: bb20325b-f4c9-47c8-bf2f-488dc6ae9360
		summarizeBy: none
		sourceColumn: Juizo

		annotation SummarizationSetBy = Automatic

	partition DimVaras = m
		mode: import
		source =
				let
				    Source = FactPericias,
				
				    NormalizeLabel = (value as any) as nullable text =>
				        let
				            Base = fnNormalizeText(value),
				            Trimmed = if Base = null then null else Text.Trim(Base),
				            Canonical = if Trimmed = null or Trimmed = "" then null else Text.Proper(Text.Lower(Trimmed)),
				            UpperValue = if Canonical = null then null else Text.Upper(Canonical)
				        in
				            if UpperValue = null or UpperValue = "" or UpperValue = "SEM INFO" then null
				            else if Text.StartsWith(UpperValue, "SEM ") then null
				            else Canonical,
				
				    BuildKey = (textValue as nullable text) as nullable text =>
				        if textValue = null then
				            null
				        else
				            let
				                Upper = Text.Upper(textValue),
				                KeptChars = Text.Select(Upper, List.Combine({{"A".."Z"}, {"0".."9"}, {" "}})),
				                Parts = List.Select(Text.Split(Text.Trim(KeptChars), " "), each _ <> ""),
				                Key = if List.Count(Parts) = 0 then null else Text.Combine(Parts, " ")
				            in
				                Key,
				
				    KeepColumns = Table.SelectColumns(Source, {"Juizo"}, MissingField.UseNull),
				    Cleaned = Table.TransformColumns(KeepColumns, {{"Juizo", each NormalizeLabel(_), type nullable text}}),
				    WithKey = Table.AddColumn(Cleaned, "JuizoKey", each BuildKey([Juizo]), type nullable text),
				    RemoveNullOrBlank = Table.SelectRows(WithKey, each [JuizoKey] <> null and Text.Trim([JuizoKey]) <> ""),
				    Grouped = Table.Group(RemoveNullOrBlank, {"JuizoKey"}, {{"Juizo", each List.Min(List.RemoveNulls([Juizo])), type nullable text}}),
				    Result = Table.SelectColumns(Grouped, {"Juizo"}),
				    Sorted = Table.Sort(Result, {{"Juizo", Order.Ascending}})
				in
				    Sorted

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

