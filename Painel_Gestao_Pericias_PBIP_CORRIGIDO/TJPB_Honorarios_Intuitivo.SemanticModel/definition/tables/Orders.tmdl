	partition Orders = calculated
		mode: import
		source =
				VAR Base =
				    FILTER (
				        FactPericias,
				        NOT ISBLANK ( FactPericias[DataRequisicao] ) &&
				        NOT ISBLANK ( FactPericias[ValorArbitrado] )
				    )
				RETURN
				    SELECTCOLUMNS (
				        Base,
				        "Row ID", 1,
				        "Order ID",
				            COALESCE (
				                FactPericias[NumeroPericia],
				                FactPericias[ProcessoNumero],
				                FactPericias[PeritoKey] & "|" & FORMAT ( FactPericias[DataRequisicao], "yyyymmdd" )
				            ),
				        "Order Date", FactPericias[DataRequisicao],
				        "Ship Date", FactPericias[DataRequisicao],
				        "Ship Mode",
				            VAR v = FactPericias[ValorArbitrado]
				            RETURN
				                IF (
				                    ISBLANK ( v ),
				                    BLANK (),
				                    IF (
				                        v < 300,
				                        "Até R$ 300",
				                        IF (
				                            v < 370,
				                            "R$ 300 - 369",
				                            IF ( v < 450, "R$ 370 - 449", IF ( v < 1000, "R$ 450 - 999", "R$ 1.000+" ) )
				                        )
				                    )
				                ),
				        "Customer ID", FactPericias[CpfCnpjDigits],
				        "Customer Name", FactPericias[PeritoNomeExibicao],
				        "Segment", FactPericias[EspeciePericia],
				        "Postal Code", BLANK (),
				        "City", FactPericias[JuizoExibicao],
				        "State", FactPericias[ComarcaExibicao],
				        "Country", "Brasil",
				        "Region", FactPericias[ComarcaExibicao],
				        "Market", "TJPB",
				        "Product ID", FactPericias[NumeroPericia],
				        "Category", FactPericias[EspecialidadeExibicao],
				        "Sub-Category", FactPericias[JuizoExibicao],
				        "Product Name", FactPericias[PeritoNomeExibicao],
				        "Sales", FactPericias[ValorArbitrado],
				        "Quantity", 1,
				        "Discount", 0,
				        "Profit", FactPericias[SaldoCalculado],
				        "Shipping Cost", BLANK (),
				        "Order Priority", FactPericias[StatusFluxo]
				    )

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

