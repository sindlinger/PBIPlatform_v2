table BridgePeritoEspecialidade
	isHidden
	lineageTag: 2bfb1277-f37d-4740-b070-fc298afdceda

	column Especialidade
		dataType: string
		lineageTag: ac9e14b6-2e5c-4226-8e3c-b8827e9f654e
		summarizeBy: none
		sourceColumn: Especialidade

		annotation SummarizationSetBy = Automatic

	column PeritoKey
		dataType: string
		isHidden
		lineageTag: 4a04c16a-e045-4245-8df0-603123342f10
		summarizeBy: none
		sourceColumn: PeritoKey

		annotation SummarizationSetBy = Automatic

	partition BridgePeritoEspecialidade = calculated
		mode: import
		source =
				DISTINCT (
				    SELECTCOLUMNS (
				        FILTER (
				            FactPericias,
				            NOT ISBLANK ( FactPericias[PeritoKey] ) &&
				            NOT ISBLANK ( FactPericias[Especialidade] )
				        ),
				        "PeritoKey", FactPericias[PeritoKey],
				        "Especialidade", FactPericias[Especialidade]
				    )
				)

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Exception

