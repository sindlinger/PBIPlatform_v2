table DimPeritos
	lineageTag: dc72f77e-13ec-40ca-b60e-de47e09470ae

	column CpfCnpjMascarado
		dataType: string
		isHidden
		lineageTag: f3ed2dc2-3c6e-4047-b465-4d3ba21a13ec
		summarizeBy: none
		sourceColumn: CpfCnpjMascarado

		annotation SummarizationSetBy = Automatic

	column PeritoKey
		dataType: string
		isHidden
		lineageTag: 7a22bb31-5fd9-47fc-9d8e-30b82e600923
		summarizeBy: none
		sourceColumn: PeritoKey

		annotation SummarizationSetBy = Automatic

	column PeritoNomeExibicao
		dataType: string
		isHidden
		lineageTag: a1c452ce-d102-443b-8135-697aaef0d7f0
		summarizeBy: none
		sourceColumn: PeritoNomeExibicao

		annotation SummarizationSetBy = Automatic

	column PeritoLabel
		dataType: string
		lineageTag: 0ae5cb42-2437-47f7-b65d-050aa1f3d9a2
		summarizeBy: none
		sourceColumn: PeritoLabel

		annotation SummarizationSetBy = Automatic

	partition DimPeritos = calculated
		mode: import
		source =
				VAR Base =
				    FILTER ( FactPericias, NOT ISBLANK ( FactPericias[PeritoKey] ) )
				RETURN
				    ADDCOLUMNS (
				        SUMMARIZE ( Base, FactPericias[PeritoKey] ),
				        "PeritoNomeExibicao", CALCULATE ( MIN ( FactPericias[PeritoNomeExibicao] ) ),
				        "PeritoLabel", CALCULATE ( MIN ( FactPericias[PeritoLabel] ) ),
				        "CpfCnpjMascarado", CALCULATE ( MIN ( FactPericias[CpfCnpjMascarado] ) )
				    )

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Exception

