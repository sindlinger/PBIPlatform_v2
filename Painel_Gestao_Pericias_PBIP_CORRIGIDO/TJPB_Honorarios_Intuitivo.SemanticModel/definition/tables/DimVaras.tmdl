table DimVaras
	lineageTag: 7e7f68f1-506e-475b-9a84-0b1c531fe4a2

	column Juizo
		dataType: string
		lineageTag: bb20325b-f4c9-47c8-bf2f-488dc6ae9360
		summarizeBy: none
		sourceColumn: Juizo

		annotation SummarizationSetBy = Automatic

	partition DimVaras = calculated
		mode: import
		source =
				DISTINCT (
				    SELECTCOLUMNS (
				        FILTER ( FactPericias, NOT ISBLANK ( FactPericias[Juizo] ) ),
				        "Juizo", FactPericias[Juizo]
				    )
				)

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Exception

