table Returns
	isHidden
	lineageTag: 4b1b9cc0-57a5-4868-984c-eacd394a4a50

	column Returned
		dataType: string
		lineageTag: 811c4a39-fb65-4432-85af-809ad2d2013a
		summarizeBy: none
		sourceColumn: Returned

		annotation SummarizationSetBy = Automatic

	column 'Order ID'
		dataType: string
		lineageTag: be6e13b8-9910-406d-b3f5-558cb152a937
		summarizeBy: none
		sourceColumn: Order ID

		annotation SummarizationSetBy = Automatic

	column Region
		dataType: string
		lineageTag: b594b867-62bf-4e85-a3f3-3886bfd5da14
		summarizeBy: none
		sourceColumn: Region

		annotation SummarizationSetBy = Automatic

	partition Returns = calculated
		mode: import
		source =
				DISTINCT (
				    SELECTCOLUMNS (
				        FILTER (
				            FactPericias,
				            NOT ISBLANK ( FactPericias[NumeroPericia] ) &&
				            FactPericias[StatusFluxo] <> "Com Adiantamento"
				        ),
				        "Returned", "Yes",
				        "Order ID", FactPericias[NumeroPericia],
				        "Region", FactPericias[ComarcaExibicao]
				    )
				)

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

